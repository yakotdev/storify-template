{
  "name": "@storify/theme-storify-template",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "node node_modules/vite/bin/vite.js build && node scripts/build-theme-manifest.mjs && cp -r config dist/",
    "preview": "vite preview",
    "zip": "npm run build && cd dist && zip -r ../storify-template-theme.zip . -x '*.DS_Store' && cd .. && echo 'تم: storify-template-theme.zip جاهز للرفع'",
    "clean": "rm -rf dist",
    "lint": "node ./node_modules/typescript/bin/tsc --noEmit"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2"
  }
}
