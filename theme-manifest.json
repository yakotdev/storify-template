      "contentSchema": {
        "title": {
          "type": "text",
          "label": "العنوان",
          "default": "آراء العملاء"
        }
      }
    },
    {
      "id": "footer",
      "name": "الفوتر",
      "component": "FOOTER",
      "group": "footer_group",
      "contentSchema": {
        "footer_menu_title": {
          "type": "text",
          "label": "عنوان القائمة",
          "default": "المتجر"
        },
        "support_menu_title": {
          "type": "text",
