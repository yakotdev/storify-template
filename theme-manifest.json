        "show_newsletter": {
          "type": "select",
          "label": "إظهار النشرة البريدية",
          "options": [
            {
              "value": "true",
              "label": "نعم"
            },
            {
              "value": "false",
              "label": "لا"
            }
          ],
          "default": "true"
