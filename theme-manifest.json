    {
      "id": "wishlist_page",
      "name": "صفحة المفضلة (نظام)",
      "component": "WISHLIST_PAGE",
      "group": "template_group",
      "contentSchema": {}
    },
    {
      "id": "track_order_page",
      "name": "تتبع الطلب (نظام)",
      "component": "TRACK_ORDER_PAGE",
      "group": "template_group",
      "contentSchema": {
        "title": {
          "type": "text",
          "label": "العنوان",
          "default": "تتبع الطلب"
        },
        "subtitle": {
          "type": "textarea",
          "label": "الوصف"
        }
      }
    },
    {
      "id": "profile_page",
      "name": "الملف الشخصي (نظام)",
      "component": "PROFILE_PAGE",
      "group": "template_group",
      "contentSchema": {
        "title": {
          "type": "text",
