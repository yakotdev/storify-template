  "pages": [
    {
      "id": "home",
      "type": "home",
      "path": "/",
      "layout": [
        {
          "sectionId": "header",
          "handle": "header",
          "defaultEnabled": true
        },
        {
          "sectionId": "hero_slider",
          "handle": "hero_slider",
          "defaultEnabled": true
        },
        {
          "sectionId": "categories",
          "handle": "categories",
          "defaultEnabled": true
        },
        {
          "sectionId": "featured_products",
          "handle": "featured_products",
          "defaultEnabled": true
        },
        {
          "sectionId": "newsletter",
          "handle": "newsletter",
          "defaultEnabled": true
        },
        {
          "sectionId": "footer",
          "handle": "footer",
          "defaultEnabled": true
        }
      ]
    },
    {
      "id": "shop",
      "type": "collection",
      "path": "/shop",
      "layout": [
        {
          "sectionId": "header",
          "handle": "header",
          "defaultEnabled": true
        },
        {
          "sectionId": "shop_page",
          "handle": "shop_page",
          "defaultEnabled": true
        },
        {
          "sectionId": "footer",
          "handle": "footer",
          "defaultEnabled": true
        }
      ]
    },
    {
      "id": "product",
      "type": "product",
      "path": "/product/:id",
      "layout": [
        {
          "sectionId": "header",
          "handle": "header",
          "defaultEnabled": true
